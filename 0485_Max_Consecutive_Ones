# Approach : Comparison_Count
# Difficulty : easy
#Time Complexity : O(n)
# Space Complexity : O(1)

```python 

class Solution(object):
    def findMaxConsecutiveOnes(self, nums):
        count=0
        maxi=0
        for i in nums:
            if i==1:
                count+=1
                if count>maxi:
                    maxi=count
            else:
                count=0
        return maxi

# Input
nums =[1,1,0,1,1,1]
# Output :
3
