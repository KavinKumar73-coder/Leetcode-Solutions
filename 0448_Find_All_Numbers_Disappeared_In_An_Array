# Approach : By using set
# Difficulty : Easy
# Time Complexity : O(n)
# Space Complexity : O(n)

```python 
class Solution(object):
    def findDisappearedNumbers(self, nums):
        s=set(nums)
        n=len(nums)
        res=[]
        for i in range(1,n+1):
            if i not in s:
                res.append(i)
        return res

Input
nums =[4,3,2,7,8,2,3,1]
Output
[5,6]
