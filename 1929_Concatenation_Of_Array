# Approach : Array,Stimulation
# Difficulty :Easy
# Time Complexity : O(n)
# Space Complexity : O(n)

```python

class Solution(object):
    def getConcatenation(self, nums):
        n=len(nums)
        arr=[0]*(2*n)      #EG:arr_lenght=3-->[0,0,0,0,0,0]
        for i in range(n):
            arr[i]=nums[i]
            arr[i+n]=nums[i]
        return arr
