# Approach : Two Pointer Method
# Time Complexity : O(n)
# space Complexity : O(1)

```python
class Solution(object):
    def reverseString(self, s):
        left=0
        right=len(s)-1
        while left<right:
            s[left],s[right]=s[right],s[left]      //Swap with respective position in reverse order
            left+=1
            right-=1
