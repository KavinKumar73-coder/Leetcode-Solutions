# Approach : Divide and Checking
# Difficulty : Easy 
# Time Complexity : O(n)
# Space Complexity : O(1)

```python
class Solution(object):
    def findNumbers(self, nums):
        count=0
        for i in nums:
            if len(str(i))%2==0:      #--->Check whether it is even or not
                count+=1
        return count



Input :
nums =[555,901,482,1771]
